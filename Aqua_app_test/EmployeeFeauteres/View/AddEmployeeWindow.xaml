<Window x:Class="Aqua.App.EmployeeFeauters.View.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aqua.App.EmployeeFeauters.View"
        mc:Ignorable="d"
        Background="Gray"
        Title="Добавить сотрудника" Height="300" Width="400">
    <Grid>
        <StackPanel Margin="10">

            <Label>Полное имя</Label>
            <TextBox Text="{Binding FullName}" />
            <Label>Позиция</Label>
            <ComboBox 
            ItemsSource="{Binding Positions}"
            SelectedItem="{Binding Position, Mode=TwoWay}" />
            <Label>Дата рождения</Label>
            <DatePicker SelectedDate="{Binding BirthDate}" />

            <Button Margin="0 10" Content="Save"
            Command="{Binding SaveCommand}" />

        </StackPanel>
    </Grid>
</Window>
